---
import { routeFile, siteRoutes } from "../lib/site-routes.js";

const { current, prefix = "../" } = Astro.props;
const primaryRoutes = siteRoutes.filter(({ nav }) => nav === "primary");
const secondaryRoutes = siteRoutes.filter(({ nav }) => nav === "secondary");
---
<nav class="route-nav primary-nav" aria-label="Primary">
    {primaryRoutes.map(({ label, path }) => (
        <a href={`${prefix}${routeFile(path)}`} aria-current={label === current ? "page" : undefined}>{label}</a>
    ))}
</nav>
<nav class="route-nav secondary-nav" aria-label="Secondary">
    {secondaryRoutes.map(({ label, path }) => (
        <a href={`${prefix}${routeFile(path)}`} aria-current={label === current ? "page" : undefined}>{label}</a>
    ))}
</nav>
