---
import RouteNav from "./RouteNav.astro";

const {
    eyebrow,
    title,
    current,
    prefix = "../"
} = Astro.props;
---
<header class="hero-header">
    <div class="hero-meta">
        <p class="eyebrow">{eyebrow}</p>
        <p class="stamp"><slot name="stamp" /></p>
    </div>
    <h1>{title}</h1>
    <slot name="context" />
</header>
<RouteNav current={current} prefix={prefix} />
