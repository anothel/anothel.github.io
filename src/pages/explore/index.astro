---
import manifest from "../../../data/manifest.json";
import trends from "../../../data/trends.json";
import packages from "../../../data/packages.json";
import repos from "../../../data/repos.json";
import links from "../../../data/links.json";
import signalPolicy from "../../../data/signal-policy.json";
import report from "../../../data/refresh-report.json";
import AppShell from "../../components/AppShell.astro";
import HeroHeader from "../../components/HeroHeader.astro";
import ExploreIsland from "../../components/ExploreIsland.jsx";
import { buildExploreFallback } from "../../lib/explore-static.js";

const fallback = buildExploreFallback({
    manifest,
    trends,
    packages,
    repos,
    links,
    signalPolicy,
    generatedAt: report.generatedAt || manifest.generatedAt
});
const dataPaths = {
    manifest: "../data/manifest.json",
    trends: "../data/trends.json",
    packages: "../data/packages.json",
    repos: "../data/repos.json",
    links: "../data/links.json",
    signalPolicy: "../data/signal-policy.json"
};
---
<AppShell title="Explore - anothel" description="Search and save tracked technical signals across HN, GitHub, npm, and references." canonicalPath="/explore/" stylesheetHref="../css/site.css">
    <div class="shell hub-shell explore-shell">
        <HeroHeader eyebrow="Cross-module search" title="Explore tracked signals." current="Explore" prefix="../">
            <Fragment slot="stamp">Search, filter, save</Fragment>
        </HeroHeader>

        <main id="main-content" class="explore-main" tabindex="-1">
            <noscript>
                <style>.explore-main astro-island .explore-command-bar,.explore-card-actions,.saved-panel,.topic-lens-actions button{display:none!important}</style>
                <section class="explore-command-bar" aria-labelledby="explore-no-js-title"><h2 id="explore-no-js-title">Browse current signals</h2><p>Current checked-in results remain available. Filtering and browser-local saving require JavaScript.</p></section>
            </noscript>
            <ExploreIsland client:load prefix="../" fallback={fallback} dataPaths={dataPaths} />
        </main>
    </div>
</AppShell>
