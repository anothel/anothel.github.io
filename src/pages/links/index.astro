---
import data from "../../../data/links.json";
import AppShell from "../../components/AppShell.astro";
import HeroHeader from "../../components/HeroHeader.astro";
import StatCard from "../../components/StatCard.astro";
import DataHealthPanel from "../../components/DataHealthPanel.astro";
import { topCategory, trustState, referenceList, externalRel } from "../../lib/site-data.js";

const validLinks = Array.isArray(data.links);
const links = referenceList(validLinks ? data.links : []);
const trust = trustState(data.sourceMeta);
const emptyTitle = !validLinks ? "Reference data invalid" : trust.pipelineStatus === "error" ? "Reference source unavailable" : "No references";
const emptyCopy = !validLinks ? "Generated reference data is missing or invalid." : trust.pipelineStatus === "error" ? "Current source did not produce usable references." : "Current data is valid but contains no references.";
---
<AppShell title="Reference shelf - anothel" description="Curated reference shelf for docs, APIs, and durable tools." canonicalPath="/links/" stylesheetHref="../css/site.css">
    <div class="shell module-shell">
        <HeroHeader eyebrow="Curated sources" title="References worth keeping close." current="Reference shelf" prefix="../">
            <Fragment slot="stamp">Data date <span data-updated>{data.updated}</span></Fragment>
        </HeroHeader>

        <main id="main-content" class="module-main" tabindex="-1">
            <section class="stats-grid source-summary" aria-label="Reference data summary" data-source-summary>
                <StatCard label="Source status" value={trust.pipelineStatus} />
                <StatCard label="Freshness" value={trust.freshness} />
                <StatCard label="Data date" value={data.updated || "unknown"} />
                <StatCard label="Records" value={links.length} />
            </section>

            <section class="rank-panel module-primary-panel" aria-labelledby="reference-title">
                <div class="panel-heading">
                    <h2 id="reference-title">Reference shelf</h2>
                    <p>Featured first, then every durable reference in source order.</p>
                </div>
                {links.length ? <div class="source-health-table-wrap source-record-table-wrap">
                    <table class="source-health-table source-record-table" aria-labelledby="reference-title" data-link-list data-source-record-list>
                        <thead><tr><th>Rank</th><th>Reference</th><th>Kind</th><th>Category</th><th>Action</th></tr></thead>
                        <tbody>{links.map((link) => <tr class:list={{ "source-record-featured": link.featured }}>
                            <td data-label="Rank"><span>#{link.rank}</span></td>
                            <th scope="row" data-label="Reference"><div>{link.featured && <span class="eyebrow">Featured</span>}<h3>{link.title || "Untitled reference"}</h3><small>{link.summary || "No summary available."}</small></div></th>
                            <td data-label="Kind"><span>{link.kind || "Unknown"}</span></td>
                            <td data-label="Category"><span>{link.category || "Unknown"}</span></td>
                            <td data-label="Action"><a href={link.url} rel={externalRel(link.url)} aria-label={`Open ${link.title || "reference"}`}>Open reference</a></td>
                        </tr>)}</tbody>
                    </table>
                </div> : <article class="rank-empty"><h3>{emptyTitle}</h3><p>{emptyCopy}</p><a href="../status/index.html">Open Status</a></article>}
            </section>

            <section class="stats-grid" aria-label="Reference stats">
                <StatCard label="References" value={links.length} />
                <StatCard label="Top category" value={topCategory(links)} />
                <StatCard label="Data status" value={data.sourceMeta?.status || "unknown"} />
            </section>

            <DataHealthPanel id="links" title="Data health" sourceMeta={data.sourceMeta} updated={data.updated} compact />
        </main>
    </div>
</AppShell>
