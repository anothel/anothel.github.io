---
import data from "../../../data/packages.json";
import AppShell from "../../components/AppShell.astro";
import HeroHeader from "../../components/HeroHeader.astro";
import StatCard from "../../components/StatCard.astro";
import DataHealthPanel from "../../components/DataHealthPanel.astro";
import { trustState, externalRel } from "../../lib/site-data.js";

const validPackages = Array.isArray(data.packages);
const packages = validPackages ? data.packages : [];
const top = packages[0];
const trust = trustState(data.sourceMeta);
const emptyTitle = !validPackages ? "Package data invalid" : trust.pipelineStatus === "error" ? "Package source unavailable" : "No package records";
const emptyCopy = !validPackages ? "Generated package data is missing or invalid." : trust.pipelineStatus === "error" ? "npm did not produce usable package records." : "Current data is valid but contains no ranked packages.";
---
<AppShell title="Packages - anothel" description="Weekly npm download movement for tools worth keeping an eye on." canonicalPath="/packages/" stylesheetHref="../css/site.css">
    <div class="shell module-shell">
        <HeroHeader eyebrow="npm movement" title="npm packages worth watching." current="Packages" prefix="../">
            <Fragment slot="stamp">Data date <span data-updated>{data.updated}</span></Fragment>
        </HeroHeader>

        <main id="main-content" class="module-main" tabindex="-1">
            <section class="stats-grid source-summary" aria-label="Package data summary" data-source-summary>
                <StatCard label="Source status" value={trust.pipelineStatus} />
                <StatCard label="Freshness" value={trust.freshness} />
                <StatCard label="Data date" value={data.updated || "unknown"} />
                <StatCard label="Records" value={packages.length} />
            </section>

            <section class="rank-panel module-primary-panel" aria-labelledby="package-title">
                <div class="panel-heading">
                    <h2 id="package-title">Weekly downloads</h2>
                    <p>Weekly download movement for tools that may be useful later.</p>
                </div>
                {packages.length ? <div class="source-health-table-wrap source-record-table-wrap">
                    <table class="source-health-table source-record-table" aria-labelledby="package-title" data-package-list data-source-record-list>
                        <thead><tr><th>Rank</th><th>Package</th><th>Category</th><th>Downloads</th><th>Focus</th></tr></thead>
                        <tbody>{packages.map((item) => <tr>
                            <td data-label="Rank"><span>#{item.rank}</span></td>
                            <th scope="row" data-label="Package"><div><h3>{item.name || "Unnamed package"}</h3><small><strong>Period</strong> {item.period || "Unknown"}</small><small><strong>Updated</strong> {data.updated || "Unknown"}</small></div></th>
                            <td data-label="Category"><span>{item.category || "Unknown"}</span></td>
                            <td data-label="Downloads"><strong>{item.downloadsLabel || "Unknown"}</strong></td>
                            <td data-label="Focus"><div><span>{item.focus || "Unknown"}</span><a href={item.url} rel={externalRel(item.url)} aria-label={`Open ${item.name || "package"} on npm`}>Open package</a></div></td>
                        </tr>)}</tbody>
                    </table>
                </div> : <article class="rank-empty"><h3>{emptyTitle}</h3><p>{emptyCopy}</p><a href="../status/index.html">Open Status</a></article>}
            </section>

            <section class="stats-grid" aria-label="Package movement stats">
                <StatCard label="Packages" value={packages.length} />
                <StatCard label="Most downloaded" value={top?.name || "-"} />
                <StatCard label="Data status" value={data.sourceMeta?.status || "unknown"} />
            </section>

            <DataHealthPanel id="packages" title="Data health" sourceMeta={data.sourceMeta} updated={data.updated} compact />
        </main>
    </div>
</AppShell>
