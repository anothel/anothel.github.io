---
import data from "../../../data/repos.json";
import AppShell from "../../components/AppShell.astro";
import HeroHeader from "../../components/HeroHeader.astro";
import SignalCard from "../../components/SignalCard.astro";
import StatCard from "../../components/StatCard.astro";
import DataHealthPanel from "../../components/DataHealthPanel.astro";
import { repoSignal, externalRel } from "../../lib/site-data.js";

const repos = data.repos || [];
const top = repos[0];
---
<AppShell title="Repos - anothel" description="GitHub project traction for repos worth keeping an eye on." canonicalPath="/repos/" stylesheetHref="../css/site.css">
    <div class="shell module-shell">
        <HeroHeader eyebrow="GitHub traction" title="Repos worth watching." current="Repos" prefix="../">
            <Fragment slot="stamp">Data date <span data-updated>{data.updated}</span></Fragment>
        </HeroHeader>

        <main class="module-main">
            <section class="module-overview-grid" aria-label="Module overview">
                <section class="stats-grid" aria-label="Repo movement stats">
                    <StatCard label="Repos" value={repos.length} />
                    <StatCard label="Top repo" value={top?.name || "-"} />
                    <StatCard label="Data status" value={data.sourceMeta?.status || "unknown"} />
                </section>
                <DataHealthPanel id="repos" title="Data health" sourceMeta={data.sourceMeta} updated={data.updated} compact />
            </section>

            <section class="dashboard-grid module-primary-panel" aria-label="Repo highlights">
                {repos.slice(0, 4).map((item) => <SignalCard item={repoSignal(item)} />)}
            </section>

            <section class="rank-panel module-primary-panel" aria-labelledby="repo-title">
                <div class="panel-heading">
                    <h2 id="repo-title">Repo traction</h2>
                    <p>GitHub stars, focus area, and latest pushed date.</p>
                </div>
                <div class="watch-head" aria-hidden="true">
                    <span>#</span><span>Repo</span><span>Category</span><span>Stars</span><span>Focus</span>
                </div>
                <div class="watch-list" data-repo-list>
                    {repos.map((item) => (
                        <a class="watch-row repo-row" href={item.url} rel={externalRel(item.url)}>
                            <span>#{item.rank}</span>
                            <strong>{item.name}</strong>
                            <span>{item.category}</span>
                            <span>{item.starsLabel} stars</span>
                            <span>{item.focus}</span>
                        </a>
                    ))}
                </div>
            </section>
        </main>
    </div>
</AppShell>
