---
import today from "../../../data/today.json";
import trends from "../../../data/trends.json";
import packages from "../../../data/packages.json";
import repos from "../../../data/repos.json";
import links from "../../../data/links.json";
import manifest from "../../../data/manifest.json";
import report from "../../../data/refresh-report.json";
import { validateDataFiles } from "../../../scripts/data-contract.mjs";
import AppShell from "../../components/AppShell.astro";
import CompactTrustSummary from "../../components/CompactTrustSummary.astro";
import HeroHeader from "../../components/HeroHeader.astro";
import SignalCard from "../../components/SignalCard.astro";
import { buildStatusDashboard } from "../../lib/status-data.mjs";

const sections = Array.isArray(today.sections) ? today.sections : [];
let validation = null;
try {
    validation = await validateDataFiles();
} catch {
    validation = null;
}
const trust = buildStatusDashboard({
    manifest,
    datasets: { trends, packages, repos, links },
    report,
    validation
});
const sectionCounts = Object.fromEntries(sections.map((section) => [
    section.id,
    Array.isArray(section.items) ? section.items.length : 0
]));
const exploreLinks = [
    ["AI agents", "../explore/index.html?focus=AI%20agents", "Agent workflow signals"],
    ["MCP", "../explore/index.html?focus=MCP", "Protocol and server references"],
    ["Agent skills", "../explore/index.html?focus=Agent%20skills", "Reusable agent instructions"],
    ["View all signals →", "../explore/index.html", "Search all tracked sources"]
];
---
<AppShell
    title="Today - anothel"
    description="Thirteen generated picks from tracked technical signals."
    canonicalPath="/today/"
    stylesheetHref="../css/site.css"
>
    <div class="shell hub-shell today-shell">
        <HeroHeader eyebrow="Open first" title="Today's priority brief." current="Today" prefix="../" />

        <main id="main-content" class="hub-main" tabindex="-1">
            <CompactTrustSummary trust={trust} statusHref="../status/index.html" />

            <p class="today-summary-line" aria-label="Today section summary" data-today-summary>
                <span><strong>{sectionCounts.start || 0}</strong> to open</span>
                <span><strong>{sectionCounts.skim || 0}</strong> to skim</span>
                <span><strong>{sectionCounts.reference || 0}</strong> references</span>
            </p>

            <section class="today-brief" data-today-sections aria-label="Today priority sections">
                {sections.map((section) => {
                    const items = Array.isArray(section.items) ? section.items : [];
                    return (
                        <section class="today-section" id={section.id} data-section-id={section.id}>
                            <div class="section-heading">
                                <div>
                                    <h2>{section.title}</h2>
                                    <p>{section.summary || `${items.length} generated picks`}</p>
                                </div>
                            </div>
                            <div class="today-grid">
                                {items.map((item) => <SignalCard item={item} variant="compact" />)}
                            </div>
                        </section>
                    );
                })}
            </section>

            <section class="explore-strip" data-today-explore aria-label="Explore full lists">
                <div>
                    <h2>Continue in Explore</h2>
                </div>
                <nav aria-label="Explore and full module pages">
                    {exploreLinks.map(([label, href, meta]) => (
                        <a href={href}>
                            <strong>{label}</strong>
                            <span class="visually-hidden">{meta}</span>
                        </a>
                    ))}
                </nav>
            </section>
        </main>
    </div>
</AppShell>
