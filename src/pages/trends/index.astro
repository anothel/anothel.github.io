---
import data from "../../../data/trends.json";
import AppShell from "../../components/AppShell.astro";
import HeroHeader from "../../components/HeroHeader.astro";
import StatCard from "../../components/StatCard.astro";
import DataHealthPanel from "../../components/DataHealthPanel.astro";
import { topCategory, trustState, externalRel } from "../../lib/site-data.js";

const validItems = Array.isArray(data.items);
const items = validItems ? data.items : [];
const top = items[0];
const trust = trustState(data.sourceMeta);
const emptyTitle = !validItems ? "Trend data invalid" : trust.pipelineStatus === "error" ? "Trend sources unavailable" : "No trend records";
const emptyCopy = !validItems ? "Generated trend data is missing or invalid." : trust.pipelineStatus === "error" ? "Current sources did not produce usable trend records." : "Current data is valid but contains no ranked trends.";
---
<AppShell title="Tech Trends - anothel" description="Ranked movement with origin, category, and momentum." canonicalPath="/trends/" stylesheetHref="../css/site.css">
    <div class="shell module-shell">
        <HeroHeader eyebrow="Cross-source movement" title="What is moving across HN, GitHub, and npm." current="Trends" prefix="../">
            <Fragment slot="stamp">Data date <span data-updated>{data.updated}</span></Fragment>
        </HeroHeader>

        <main id="main-content" class="module-main" tabindex="-1">
            <section class="stats-grid source-summary" aria-label="Trend data summary" data-source-summary>
                <StatCard label="Source status" value={trust.pipelineStatus} />
                <StatCard label="Freshness" value={trust.freshness} />
                <StatCard label="Data date" value={data.updated || "unknown"} />
                <StatCard label="Records" value={items.length} />
            </section>

            <section class="rank-panel module-primary-panel" aria-labelledby="rank-title">
                <div class="panel-heading">
                    <h2 id="rank-title">Signal table</h2>
                    <p>Ranked movement across source, category, score, and momentum.</p>
                </div>
                {items.length ? <div class="source-health-table-wrap source-record-table-wrap">
                    <table class="source-health-table source-record-table" aria-labelledby="rank-title" data-source-record-list>
                        <thead><tr><th>Rank</th><th>Signal</th><th>Category</th><th>Origin</th><th>Score</th></tr></thead>
                        <tbody>{items.map((item) => <tr>
                            <td data-label="Rank"><span>{item.rank}</span></td>
                            <th scope="row" data-label="Signal"><div><h3>{item.title || "Untitled signal"}</h3><small><strong>Velocity</strong> {item.velocity || "Unknown"}</small><small><strong>Summary</strong> {item.summary || "No summary available."}</small></div></th>
                            <td data-label="Category"><span>{item.category || "Unknown"}</span></td>
                            <td data-label="Origin"><span>{item.source || "Unknown"}</span></td>
                            <td data-label="Score"><div><strong>{item.score ?? "Unknown"}</strong><small><strong>Signal fit</strong> {item.signal || "Unknown"}</small><small><strong>Updated</strong> {data.updated || "Unknown"}</small><a href={item.url} rel={externalRel(item.url)} aria-label={`Open ${item.title || "signal"} source`}>Open signal</a></div></td>
                        </tr>)}</tbody>
                    </table>
                </div> : <article class="rank-empty"><h3>{emptyTitle}</h3><p>{emptyCopy}</p><a href="../status/index.html">Open Status</a></article>}
            </section>

            <section class="stats-grid" aria-label="Trend statistics">
                <StatCard label="Signals" value={items.length} />
                <StatCard label="Highest score" value={top?.score ?? "-"} />
                <StatCard label="Leading category" value={topCategory(items)} />
            </section>

            <DataHealthPanel id="trends" title="Source health" sourceMeta={data.sourceMeta} updated={data.updated} compact />
        </main>
    </div>
</AppShell>
