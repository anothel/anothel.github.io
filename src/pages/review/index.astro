---
import AppShell from "../../components/AppShell.astro";
import HeroHeader from "../../components/HeroHeader.astro";
import ReviewIsland from "../../components/ReviewIsland.jsx";

const dataPaths = {
    trends: "../data/trends.json",
    packages: "../data/packages.json",
    repos: "../data/repos.json",
    links: "../data/links.json"
};
---
<AppShell title="Review - anothel" description="Saved technical signals to review later in this browser." canonicalPath="/review/" stylesheetHref="../css/site.css">
    <div class="shell hub-shell">
        <HeroHeader eyebrow="Saved queue" title="Review later." current="Review" prefix="../">
            <Fragment slot="stamp">Saved locally in this browser.</Fragment>
        </HeroHeader>

        <main id="main-content" class="hub-main" tabindex="-1">
            <ReviewIsland client:load prefix="../" dataPaths={dataPaths} />
        </main>
    </div>
</AppShell>
