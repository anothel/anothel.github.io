---
import manifest from "../../data/manifest.json";
import today from "../../data/today.json";
import trends from "../../data/trends.json";
import packages from "../../data/packages.json";
import repos from "../../data/repos.json";
import links from "../../data/links.json";
import report from "../../data/refresh-report.json";
import { validateDataFiles } from "../../scripts/data-contract.mjs";
import AppShell from "../components/AppShell.astro";
import CompactTrustSummary from "../components/CompactTrustSummary.astro";
import HeroHeader from "../components/HeroHeader.astro";
import SignalCard from "../components/SignalCard.astro";
import { buildStatusDashboard } from "../lib/status-data.mjs";

const modules = manifest.modules || [];
const startItems = today.sections?.find((section) => section.id === "start")?.items || [];
const skimItems = today.sections?.find((section) => section.id === "skim")?.items || [];
const total = modules.reduce((sum, module) => sum + (module.count || 0), 0);
const updated = modules.map((module) => module.updated).filter(Boolean).sort().at(-1) || manifest.updated || "-";
let validation = null;
try {
    validation = await validateDataFiles();
} catch {
    validation = null;
}
const trust = buildStatusDashboard({
    manifest,
    datasets: { trends, packages, repos, links },
    report,
    validation
});
const moduleRoutes = [
    { title: "Explore workspace", route: "explore/index.html", purpose: "Search and save across sources", count: total, updated, status: "ok" },
    { title: "Source status", route: "status/index.html", purpose: "Refresh health across sources", count: total, updated, status: "ok" },
    ...modules.map((module) => ({
        title: module.title,
        route: module.route,
        purpose: module.id === "trends" ? "Cross-source movement" : module.source,
        count: module.count,
        updated: module.updated,
        status: module.status
    }))
];
---
<AppShell
    title="anothel"
    description="A personal radar for AI engineering signals across HN, GitHub, npm, repos, packages, and curated references."
    canonicalPath="/"
    stylesheetHref="css/site.css"
>
    <div class="shell hub-shell">
        <HeroHeader eyebrow="Personal signal radar" title="What is worth opening now?" current="Home" prefix="">
            <Fragment slot="stamp">Priority-ranked signals</Fragment>
        </HeroHeader>

        <main id="main-content" class="hub-main" tabindex="-1">
            <section class="home-command-board" aria-labelledby="home-priority-title">
                <div class="home-priority-panel">
                    <div class="section-heading">
                        <div>
                            <p class="eyebrow">Open first</p>
                            <h2 id="home-priority-title">Start with these signals.</h2>
                            <p>A personal radar for AI engineering signals across HN, GitHub, npm, repos, packages, and references.</p>
                        </div>
                        <a href="today/index.html">Open priority brief</a>
                    </div>
                    {startItems.map((item, index) => (
                        <div class:list={["home-priority-signal", { "home-priority-signal-first": index === 0 }]}>
                            <SignalCard item={item} variant="compact" />
                        </div>
                    ))}

                    <section class="home-saved-summary" aria-label="Local saved queue" data-home-review-summary>
                        <div class="home-saved-facts">
                            <span>Items tracked <strong data-home-total>{total}</strong></span>
                            <span>Saved <strong data-home-review-saved>??</strong></span>
                            <span>Unread <strong data-home-review-unread>??</strong></span>
                        </div>
                        <p data-home-review-status aria-live="polite">Browser-local state loads when JavaScript is available. <a href="review/index.html">Open Review</a></p>
                    </section>

                    <CompactTrustSummary trust={trust} statusHref="status/index.html" />
                </div>
            </section>

            <section class="home-module-section" aria-labelledby="home-modules-title">
                <div class="section-heading">
                    <div>
                        <h2 id="home-modules-title">Browse modules</h2>
                        <p>Jump into the workspace when a source deserves deeper reading.</p>
                    </div>
                    <a href="explore/index.html">Search all tracked signals</a>
                </div>
                <section class="module-strip home-module-board" aria-label="Module routes" data-home-routes>
                    {moduleRoutes.map((route) => (
                        <a class={`module-route status-${route.status || "unknown"}`} href={route.route}>
                            <span>{route.title}</span>
                            <strong>{route.purpose}</strong>
                            <small>{route.count} items / {route.updated} / Status {route.status}</small>
                        </a>
                    ))}
                </section>
            </section>

            <section class="home-project-section" aria-labelledby="home-projects-title">
                <div class="section-heading">
                    <div>
                        <h2 id="home-projects-title">Projects</h2>
                        <p>Small things worth opening directly.</p>
                    </div>
                </div>
                <div class="project-list">
                    <a class="project-card" href="https://anothel.github.io/securekit/" rel="noopener noreferrer">
                        <strong>SecureKit</strong>
                        <span>C++20 security utility library backed by OpenSSL 3.x</span>
                    </a>
                </div>
            </section>

            <section class="home-skim-panel" aria-labelledby="skim-title">
                <div class="section-heading">
                    <div>
                        <h2 id="skim-title">Worth skimming</h2>
                        <p>Useful signals that do not need first attention.</p>
                    </div>
                </div>
                <div class="skim-list" data-home-skim>
                    {skimItems.slice(0, 8).map((item) => (
                        <a class="skim-item" href={item.url}>
                            <strong>{item.title}</strong>
                            <span>{item.module} / {item.metric}</span>
                        </a>
                    ))}
                </div>
            </section>
        </main>
    </div>
    <script>
        import { initHomeSavedSummary } from "../scripts/home-saved-summary.js";

        initHomeSavedSummary();
    </script>
</AppShell>
