---
import AppShell from "../../components/AppShell.astro";
import HeroHeader from "../../components/HeroHeader.astro";
import { topicNotes } from "../../lib/topic-taxonomy.js";

const notes = topicNotes("../");
const title = "Topic notes - anothel";
const description = "Judgment notes from focused topic pages.";
---
<AppShell
    title={title}
    description={description}
    canonicalPath="/notes/"
    stylesheetHref="../css/site.css"
>
    <Fragment slot="head">
        <meta name="twitter:card" content="summary">
        <meta name="twitter:title" content={title}>
        <meta name="twitter:description" content={description}>
    </Fragment>

    <div class="shell hub-shell">
        <HeroHeader eyebrow="Decision context" title="Topic notes." current="Notes" prefix="../">
            <Fragment slot="stamp"><span data-notes-count>{notes.length}</span> notes</Fragment>
        </HeroHeader>

        <main id="main-content" class="hub-main" tabindex="-1">
            <section class="topic-note-panel topic-cross-link-grid notes-grid" aria-labelledby="notes-list-title" data-notes-list>
                <h2 class="visually-hidden" id="notes-list-title">Topic notes</h2>
                {notes.map((item) => (
                    <article class="topic-note-card notes-card">
                        <div>
                            <span>{item.topic}</span>
                            <h3>{item.note.title}</h3>
                        </div>
                        <nav class="topic-support-list notes-card-actions" aria-label={`${item.topic} note actions`}>
                            <a href={item.route}>
                                <strong>Open topic</strong>
                                <span>{item.topic}</span>
                            </a>
                            <a href={item.exploreRoute}>
                                <strong>Explore lens</strong>
                                <span>{item.topic}</span>
                            </a>
                        </nav>
                        <div class="notes-card-copy">
                            <p>{item.note.body}</p>
                            <small>{item.note.readWhen}</small>
                            <p>{item.description}</p>
                        </div>
                    </article>
                ))}
            </section>
        </main>
    </div>
</AppShell>
